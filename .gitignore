# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# MSI package
*.msi

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Coverage artifacts (make cover)
/coverage/
/coverage.txt

# SQLite database file
*.db*

# Dependency directories
/vendor

# Visual Studio Code
/.vscode/*
!/.vscode/launch.json

# Debug
*__debug_*
*.prof
/goroutine-dump*.txt
/data*.js
/data-*.json
/myhome.yaml

# Certificates
*.pfx
/secrets.sh
SECRETS.md

# Code signing certificates
*.pfx
*.key

# goreleaser
/dist

# Claude Code worktrees
/worktrees
/.claude/worktrees

# Local credentials (see example.env / CONTRIBUTING.md "Local Credentials")
.env
.env.local

# Local files
/myhome/ctl/homectl*
/myhome/myhome*
/myip/myip*
/mqtt-cli-*.deb
/wix.build.json
/myhome/ctl/shelly*/*.js
/myhome/events/*.db
/myhome/device*.json
/device*.json
myhome_*.deb
database-export.json
internal/myhome/ui/static/bulma.min.css
dist/artifacts.json
dist/config.yaml
dist/metadata.json
internal/myhome/ui/static/alpine.min.js
internal/myhome/ui/static/htmx.min.js
myhome/ctl/pool/pool_defaults_generated.go
myhome/ctl/garden/garden_defaults_generated.go
