# example.env — template for local myhome credentials.
#
# Copy this file to `.env` (never committed — see .gitignore) and fill in real
# values, then load it into your shell before running the daemon locally:
#
#   cp example.env .env
#   set -a; source .env; set +a
#   go run ./myhome daemon run --mqtt-broker tcp://192.168.1.2:1883
#
# NOTE: myhome does NOT auto-load .env the way python-dotenv does — Viper only
# reads these from the real process environment (via AutomaticEnv), so you
# must source this file yourself. In production, /var/lib/myhome/.env is
# written by `dpkg-reconfigure myhome` and loaded via the systemd unit's
# EnvironmentFile= directive — same convention, different location.
#
# Full reference for every config key (env var, flag, default, description):
# docs/configuration.md

# --- Beem Energy (solar production) ---
# Enabled automatically once both are non-empty. No separate enable flag.
MYHOME_BEEM_EMAIL=
MYHOME_BEEM_PASSWORD=

# --- SFR Box (home gateway) ---
# Authentication is skipped when either is empty.
MYHOME_SFR_USERNAME=
MYHOME_SFR_PASSWORD=

# --- SMTP (notice digest email) ---
# Leave MYHOME_SMTP_FROM blank to disable email sending entirely.
MYHOME_SMTP_USERNAME=
MYHOME_SMTP_PASSWORD=
MYHOME_SMTP_FROM=
MYHOME_SMTP_TO=
